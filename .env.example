# Copy to .env (or set these in the service environment) and adjust.

# --- Branding / public identity ---
APP_TITLE="Sensor Board"
BRAND="Sensor Board"
# Public base URL, no trailing slash (used for shareable links).
BASE_URL="https://sensors.example.com"

# --- Ingestion ---
API_KEY="change-me"
# Path devices POST measurements to.
INGEST_PATH="/sensor/measurement"

# --- Storage ---
# DB_PATH="/home/USER/sensor_board/app/data/sensors.db"

# --- Frontend ---
# ECHARTS_SRC="/static/js/echarts.min.js"
DEFAULT_RANGE_HOURS=168
