# Copy to .env (or set these in the service environment) and adjust.

# --- Branding / public identity ---
APP_TITLE="Sensor Board"
BRAND="Sensor Board"
# Public base URL, no trailing slash (used for shareable links).
BASE_URL="https://sensors.example.com"

# --- Mount path ---
# URL prefix the UI is served under. "" = domain root; "/dashboard" = under
# /dashboard/… . The ingest endpoint is independent of this.
ROOT_PATH=""

# --- Ingestion ---
# One key:
API_KEY="change-me"
# ...or several (comma-separated) — e.g. one per workshop/group. If set, this
# takes precedence over API_KEY. Any listed key is accepted as x-api-key.
# API_KEYS="workshop-a-key,workshop-b-key,admin-key"
# Path devices POST measurements to.
INGEST_PATH="/sensor/measurement"

# --- Storage ---
# DB_PATH="/home/USER/sensor_board/app/data/sensors.db"

# --- Frontend ---
# ECHARTS_SRC="/static/js/echarts.min.js"
DEFAULT_RANGE_HOURS=168
