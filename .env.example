# Copy to .env (or set these in the service environment) and adjust.

# --- Branding / public identity ---
APP_TITLE="Sensor Board"
BRAND="Sensor Board"
# Public base URL, no trailing slash (used for shareable links).
BASE_URL="https://sensors.example.com"

# --- Mount path ---
# URL prefix the UI is served under. "" = domain root; "/dashboard" = under
# /dashboard/… . The ingest endpoint is independent of this.
ROOT_PATH=""

# --- Ingestion ---
# One key:
API_KEY="change-me"
# ...or several (comma-separated) — e.g. one per workshop/group. If set, this
# takes precedence over API_KEY. Any listed key is accepted as x-api-key.
# API_KEYS="workshop-a-key,workshop-b-key,admin-key"
# Path devices POST measurements to.
INGEST_PATH="/sensor/measurement"
# Reject ingest bodies larger than this many bytes (default 50 KB).
# MAX_PAYLOAD_BYTES=51200

# --- Storage ---
# DB_PATH="/home/USER/sensor_board/app/data/sensors.db"

# --- Retention (automatic cleanup) ---
# A device is deleted once its newest reading is older than RETENTION_HOURS; a
# project disappears automatically when all of its devices are gone. Set to 0 to
# disable automatic deletion entirely.
# RETENTION_HOURS=48
# How often the background sweeper runs, in hours.
# RETENTION_SWEEP_INTERVAL_HOURS=1
# Exceptions: comma-separated device UUIDs and/or project names that are never
# auto-deleted, however long they stay silent. A device is spared if its UUID is
# exempt OR its latest project is exempt.
# RETENTION_EXEMPT_DEVICES="reference-station,demo-device-01"
# RETENTION_EXEMPT_PROJECTS="permanent-exhibit"

# --- Frontend ---
# ECHARTS_SRC="/static/js/echarts.min.js"
DEFAULT_RANGE_HOURS=168
